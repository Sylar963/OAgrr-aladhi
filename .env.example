PORT=3100
NODE_ENV=production
LOG_LEVEL=info

# Venue credentials (optional — when absent the affected venue degrades
# gracefully: chain/WS no-ops or chart panels fall back to the live
# MarkHistoryBuffer instead of REST history).
#
# Coincall: chain WS, live-trade tape, and REST kline history all sign.
COINCALL_API_KEY=
COINCALL_API_SECRET=
#
# Gate.io: only /options/mark_price_candlesticks (signed mark-history) is
# auth-gated today; chain/WS/trade-tape stay public.
GATEIO_API_KEY=
GATEIO_API_SECRET=

# Private portfolio adapters (Derive, Thalex) accept raw signing keys — an ETH
# private key / RSA PEM — over the POST /api/portfolio/venue-credentials path.
# Keys live in memory only (never persisted/logged), but submitting them at all
# is unsafe on a shared/public deployment. Off by default: the endpoint returns
# 403 unless this is set. Enable ONLY on a trusted self-hosted instance.
PRIVATE_VENUE_ADAPTERS_ENABLED=

# Optional: path to a JSON file the server reads to surface a site-wide status
# announcement on GET /api/health. Edit the file to flip a flag (no restart).
# Shape: { "id", "severity": info|notice|degraded|outage, "blocking": bool,
#          "title", "message"?, "startsAt"?: epochMs, "endsAt"?: epochMs }
# severity sets tone/color; "blocking": true is what renders a full-screen
# takeover (an outage with blocking:false is still just a sticky banner).
# Empty file / null / invalid → no announcement.
STATUS_FILE=

# Clerk (real identity). When DATABASE_URL is set (prod), the paper/portfolio
# routes + WS require a verified Clerk JWT. When DATABASE_URL is absent (local
# dev / hermetic tests), auth is skipped and requests resolve to the default
# paper account — no Clerk needed.
#
# Server-side (Scaleway): verify tokens networklessly against Clerk's JWKS.
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
#
# Frontend (Vite SPA): public publishable key for the Clerk React SDK.
VITE_CLERK_PUBLISHABLE_KEY=
