PORT=3100
NODE_ENV=production
LOG_LEVEL=info

# --- TradFi (TastyTrade) backend — @oggregator/tradfi, separate process on :3200 ---
# Real secrets live ONLY in the gitignored repo-root .env on the host, never in git.
# Personal OAuth2 grant from my.tastytrade.com → app → Manage → Create Grant (read scope).
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
TRADFI_PORT=3200
TRADFI_UNDERLYINGS=SPX,NDX,SPY,QQQ,AAPL,NVDA,TSLA
# Optional overrides:
# TASTYTRADE_BASE_URL=https://api.tastyworks.com
# TASTYTRADE_USER_AGENT=oggregator-tradfi/0.1
