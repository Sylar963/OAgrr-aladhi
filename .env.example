PORT=3100
NODE_ENV=production
LOG_LEVEL=info

# Venue credentials (optional — when absent the affected venue degrades
# gracefully: chain/WS no-ops or chart panels fall back to the live
# MarkHistoryBuffer instead of REST history).
#
# Coincall: chain WS, live-trade tape, and REST kline history all sign.
COINCALL_API_KEY=
COINCALL_API_SECRET=
#
# Gate.io: only /options/mark_price_candlesticks (signed mark-history) is
# auth-gated today; chain/WS/trade-tape stay public.
GATEIO_API_KEY=
GATEIO_API_SECRET=

# Optional: path to a JSON file the server reads to surface a site-wide status
# announcement on GET /api/health. Edit the file to flip a flag (no restart).
# Shape: { "id", "severity": info|notice|degraded|outage, "blocking": bool,
#          "title", "message"?, "startsAt"?: epochMs, "endsAt"?: epochMs }
# severity sets tone/color; "blocking": true is what renders a full-screen
# takeover (an outage with blocking:false is still just a sticky banner).
# Empty file / null / invalid → no announcement.
STATUS_FILE=
