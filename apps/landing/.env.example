# Launch-CTA target — the live SPA the landing hands users off to.
# Client-exposed: inlined into the bundle at build time.
NEXT_PUBLIC_APP_URL=https://app.oggregator.xyz

# Core API base for ISR market data + server-to-server lead forwarding.
# Server-only (never exposed to the browser). Unset locally to fall back to
# demo data + the local JSONL lead sink.
LANDING_API_BASE_URL=https://api.oggregator.xyz

# Fallback lead sink path, used when the API is unreachable / has no DB.
# Defaults to apps/landing/.data/landing-leads.jsonl when unset.
LANDING_LEADS_FILE=
